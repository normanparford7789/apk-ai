<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="#F2FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_task_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🤖 AI Control"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:ellipsize="end"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/btn_close_panel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#666666"
                android:padding="4dp"
                android:contentDescription="إغلاق" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="في وضع الاستعداد"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <!-- Chat messages list -->
        <ScrollView
            android:id="@+id/scroll_chat"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chat_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp" />
        </ScrollView>

        <!-- Input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/et_chat_input"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="اكتب أمراً للذكاء الاصطناعي..."
                android:textSize="13sp"
                android:background="@drawable/chat_input_bg"
                android:paddingHorizontal="10dp"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:inputType="text" />

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:background="@drawable/chat_send_bg"
                android:contentDescription="إرسال"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Bottom buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/btn_open_app"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="فتح التطبيق"
                android:gravity="center"
                android:textColor="#555555"
                android:textSize="12sp"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/btn_clear_chat"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="مسح المحادثة"
                android:gravity="center"
                android:textColor="#555555"
                android:textSize="12sp"
                android:background="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
