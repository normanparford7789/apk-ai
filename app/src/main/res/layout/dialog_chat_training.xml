<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 محادثة تدريب الذكاء الاصطناعي"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E" />

        <ImageButton
            android:id="@+id/btn_close_chat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#666666"
            android:contentDescription="إغلاق" />
    </LinearLayout>

    <!-- Chat messages -->
    <ScrollView
        android:id="@+id/scroll_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_chat"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="4dp" />

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="اكتب رسالة..."
            android:textSize="14sp"
            android:background="@drawable/chat_input_bg"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:background="@drawable/chat_send_bg"
            android:contentDescription="إرسال"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Save button -->
    <Button
        android:id="@+id/btn_save_task"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="💾 حفظ كمهمة"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_start_bg"
        android:layout_margin="8dp" />

</LinearLayout>
