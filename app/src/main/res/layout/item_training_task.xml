<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="عنوان المهمة"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_active_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● نشط"
                android:textSize="11sp"
                android:textColor="#4CAF50"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_star_outline"
                android:contentDescription="مفضلة"
                android:padding="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="وصف المهمة..."
            android:textSize="13sp"
            android:textColor="#666"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عام"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/category_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tv_run_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="تشغيلات: 0"
                android:textSize="11sp"
                android:textColor="#888"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2025"
                android:textSize="11sp"
                android:textColor="#888"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_activate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="تفعيل"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
